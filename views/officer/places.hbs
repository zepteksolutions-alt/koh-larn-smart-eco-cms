{{> shell_top}}

<div class="table-wrap">
  <table class="tbl">
    <thead><tr><th>สถานที่</th><th>ประเภท</th><th>ผู้ประกอบการ</th><th>พื้นที่</th><th>สถานะ</th><th style="text-align:right">จัดการ</th></tr></thead>
    <tbody>
      {{#each places}}
      <tr>
        <td class="cell-name">
          <img src="{{this.image}}" alt="">
          <b>{{this.name}}</b>
        </td>
        <td><span class="type-tag">{{typeLabel this.type}}</span></td>
        <td>{{this.ownerName}}</td>
        <td class="muted">{{this.area}}</td>
        <td><span class="badge-st {{this.status}}">{{statusLabel this.status}}</span></td>
        <td>
          <div class="row-actions">
            {{#if (eq this.status 'pending')}}
            <form method="post" action="/officer/approvals/{{this.id}}/approve">
              <button class="btn btn-teal sm" type="submit"><span class="btn-ic">{{{icon "check"}}}</span>อนุมัติ</button>
            </form>
            {{/if}}
            {{#if (eq this.status 'approved')}}
            <button type="button" class="btn btn-warn sm" onclick="openReject('/officer/approvals/{{this.id}}/reject', '{{this.name}}', 'ยกเลิกการอนุมัติ')">ยกเลิกการอนุมัติ</button>
            {{/if}}
            <form method="post" action="/officer/places/{{this.id}}/delete" onsubmit="return confirm('ลบสถานที่นี้ถาวร?')">
              <button class="btn btn-danger sm" type="submit">ลบ</button>
            </form>
          </div>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>

{{> reject_modal}}
{{> shell_bottom}}
