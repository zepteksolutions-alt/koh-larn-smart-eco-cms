<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>เข้าสู่ระบบ · Koh Larn CMS</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&family=Noto+Sans+Thai:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/styles.css">
</head>
<body class="login-body">
  <div class="login-card">
    <div class="login-head">
      <div class="logo-lg">{{{icon "island"}}}</div>
      <h2>Koh Larn Smart Eco</h2>
      <p>ระบบจัดการหลังบ้าน (CMS)</p>
    </div>

    {{#if ok}}
      <div class="alert ok">สมัครสมาชิกสำเร็จ เข้าสู่ระบบได้เลย</div>
    {{/if}}
    {{#if error}}
      <div class="alert">
        {{#if (eq error 'officer')}}Username หรือ Password ไม่ถูกต้อง{{/if}}
        {{#if (eq error 'op')}}อีเมลหรือรหัสผ่านไม่ถูกต้อง{{/if}}
      </div>
    {{/if}}

    <div class="seg">
      <button type="button" class="seg-btn active" id="tabOp" onclick="pick('operator')">ผู้ประกอบการ</button>
      <button type="button" class="seg-btn" id="tabOff" onclick="pick('officer')">เจ้าหน้าที่</button>
    </div>

    <!-- ผู้ประกอบการ -->
    <form method="post" action="/login" id="formOp" class="login-form">
      <input type="hidden" name="role" value="operator">
      <label>อีเมล</label>
      <div class="input-ic">
        <span class="ic">{{{icon "mail"}}}</span>
        <input type="email" name="email" class="field" placeholder="you@example.com" required>
      </div>
      <label>รหัสผ่าน</label>
      <div class="input-ic">
        <span class="ic">{{{icon "lock"}}}</span>
        <input type="password" name="password" class="field" placeholder="รหัสผ่าน" required>
      </div>
      <button class="btn btn-teal btn-block" type="submit">เข้าสู่ระบบ</button>
      <p class="hint">ยังไม่มีบัญชี? <a href="/register" class="link">สมัครสมาชิกผู้ประกอบการ</a></p>
      <p class="hint">บัญชีเดโม: <b>seaview@kohlarn.app</b> / <b>123456</b></p>
    </form>

    <!-- เจ้าหน้าที่ -->
    <form method="post" action="/login" id="formOff" class="login-form" style="display:none">
      <input type="hidden" name="role" value="officer">
      <label>Username</label>
      <div class="input-ic">
        <span class="ic">{{{icon "user"}}}</span>
        <input type="text" name="username" class="field" placeholder="ชื่อผู้ใช้เจ้าหน้าที่" required autocomplete="off">
      </div>
      <label>Password</label>
      <div class="input-ic">
        <span class="ic">{{{icon "lock"}}}</span>
        <input type="password" name="password" class="field" placeholder="รหัสผ่าน" required autocomplete="off">
      </div>
      <button class="btn btn-teal btn-block" type="submit">เข้าสู่ระบบ</button>
      <p class="hint">บัญชีเดโม: <b>admin</b> / <b>admin1234</b></p>
    </form>
  </div>

  <script>
    function pick(role){
      var op = role === 'operator';
      document.getElementById('tabOp').classList.toggle('active', op);
      document.getElementById('tabOff').classList.toggle('active', !op);
      document.getElementById('formOp').style.display = op ? 'block' : 'none';
      document.getElementById('formOff').style.display = op ? 'none' : 'block';
    }
  </script>
</body>
</html>
